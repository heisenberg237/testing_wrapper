# Application logging
LOG_LEVEL=INFO
CONSOLE_LOG=true

# Runtime directories (optional)
OUTPUT_DIR=output
TEMP_DIR=temp

# Processing options
ENABLE_OP_DATA=false
ENABLE_NOTIFICATIONS=false
# NOTIFICATION_EMAIL=you@example.com

# MongoDB options (optional integration)
MONGO_URI= 
MONGO_DB=mleHeatmap
MONGO_DB_MLEDATA=mleData
MONGO_COLLECTION_MLEDATA=mleTracking

# Daily batch script defaults (run_daily.sh)
DAILY_PART_NUMBER=362
DAILY_SUPPLIER=MLX
DAILY_INPUT_DIR=data/in/mlx
DAILY_OUTPUT_DIR=output
DAILY_METRICS=widthness,tangent,chords,thickness_extrados,thickness_intrados
# DAILY_NOMINAL_FILE=/absolute/path/to/nominal.csv
